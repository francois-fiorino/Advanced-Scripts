#!/bin/bash
#
# ---------------------------------------------------------------------------
# Script: backup_full_rman.sh
# Objetivo:
#   Executar rotina de backup full (incremental level 0) via RMAN,
#   incluindo:
#     - limpeza de backups/logs antigos
#     - crosscheck de backups e archivelogs
#     - remoção de backups obsoletos e expirados
#     - backup do database
#     - backup dos archivelogs
#     - backup do controlfile
#     - backup do spfile
#   Ao final, consulta o status da execução e envia notificação por e-mail.
#
# Observações:
#   - Este exemplo utiliza dados fictícios.
#   - Em produção, não armazene senhas em texto claro no script.
#   - Prefira Oracle Wallet, OS authentication ou solução segura de secrets.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# 1) Variáveis de ambiente Oracle
# ---------------------------------------------------------------------------
export ORACLE_SID=DBPRD
export ORACLE_BASE=/u01/app/oracle
export ORACLE_HOME=/u01/app/oracle/product/19.0.0.0/dbhome_1
export PATH=$PATH:$HOME/.local/bin:$HOME/bin:$ORACLE_BASE:$ORACLE_HOME:$ORACLE_HOME/bin

# Data/hora usada para identificar log e execução
export DATE=$(date +%d-%m-%y_%H%M%S)

# ---------------------------------------------------------------------------
# 2) Limpeza de arquivos antigos
#    - Remove backups full com mais de 7 dias
#    - Remove logs antigos da rotina com mais de 7 dias
# ---------------------------------------------------------------------------
find /backup/rman/full/ -type f -mtime +7 -exec rm -f {} \;
find /backup/logs_rman/ -iname "DBPRD_Full_*" -type f -mtime +7 -exec rm -f {} \;

# Identificador único da execução
RUN_ID="FULL_${DATE}"

# ---------------------------------------------------------------------------
# 3) Execução do RMAN
#    Etapas:
#      - Aloca 2 canais em disco
#      - Faz crosscheck de backup, copy e archivelog
#      - Remove backups obsoletos
#      - Remove backups expirados
#      - Força archive log current
#      - Executa backup incremental level 0 do banco
#      - Executa backup dos archivelogs ainda não copiados
#      - Executa backup do controlfile
#      - Executa backup do spfile
# ---------------------------------------------------------------------------
rman target / log=/backup/logs_rman/DBPRD_Full_${DATE}.log << EOF

set echo on;

run {
    set command id to '${RUN_ID}';
    allocate channel ch01 device type disk;
    allocate channel ch02 device type disk;

    crosscheck backup;
    crosscheck copy;
    crosscheck archivelog all;

    delete noprompt obsolete device type disk;
    delete force noprompt expired backup;

    sql 'alter system archive log current';

    backup incremental level 0
        format '/backup/rman/full/Full_inc0-%T-%I-%d-%s.bkp'
        database
        tag 'BKP_LEVEL0';

    backup format '/backup/rman/archivelog/archive-%T-%I-%d-%s.bkp'
        archivelog all not backed up
        tag 'BKP_ARCHIVELOG';

    backup format '/backup/rman/controlfile/control-%T-%I-%d-%s.bkp'
        current controlfile
        tag 'BKP_CONTROLFILE';

    backup format '/backup/rman/controlfile/spfile-%T-%I-%d-%s.bkp'
        spfile
        tag 'BKP_SPFILE';

    release channel ch01;
    release channel ch02;
}
EOF

# ---------------------------------------------------------------------------
# 4) Consulta o status final da execução RMAN
#    Busca o status do job com base no COMMAND_ID em
#    V$RMAN_BACKUP_JOB_DETAILS
# ---------------------------------------------------------------------------
status_last_backup=$(sqlplus -s system/SenhaFicticia123<<EOF
set newpage 0
set echo off
set feedback off
set heading off
set pages 0
set verify off
set trimspool on
SELECT status
FROM V\$RMAN_BACKUP_JOB_DETAILS
WHERE command_id = '${RUN_ID}'
  AND status NOT LIKE 'RUNNING%'
ORDER BY end_time DESC
FETCH FIRST 1 ROWS ONLY;
exit
EOF
)

# Remove espaços em branco excedentes
status_last_backup=$(echo "$status_last_backup" | xargs)

# ---------------------------------------------------------------------------
# 5) Configuração comum para envio de e-mail
# ---------------------------------------------------------------------------
EMAIL_SUBJECT="Rotina Backup Full"
FROM_EMAIL_ADDRESS="backup.monitor@empresa.com"
FRIENDLY_NAME="RMAN Backup"
SMTP_SERVER="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="backup.monitor@empresa.com"
SMTP_PASS="SenhaSMTPFicticia@123"
TO_EMAIL_ADDRESS="dba1@empresa.com dba2@empresa.com"
FILEPATH="/backup/logs_rman/DBPRD_Full_${DATE}.log"
# Diretório NSS utilizado pelo mailx para TLS/SSL
NSS_DIR="/etc/pki/nssdb/"

# ---------------------------------------------------------------------------
# 6) Envia e-mail conforme status final da execução
#    - FAILED  -> e-mail de falha
#    - demais  -> e-mail de sucesso
# ---------------------------------------------------------------------------
if [[ "$status_last_backup" = "FAILED" ]]; then
    MESSAGE_BODY="========== BACKUP TERMINADO COM FALHAS =========="
    echo "$MESSAGE_BODY" | mailx -v -s "$EMAIL_SUBJECT" \
        -S smtp-use-starttls \
        -S ssl-verify=ignore \
        -S smtp=smtp://$SMTP_SERVER:$SMTP_PORT \
        -S from="$FROM_EMAIL_ADDRESS($FRIENDLY_NAME)" \
        -S smtp-auth-user=$SMTP_USER \
        -S smtp-auth-password=$SMTP_PASS \
        -S nss-config-dir=$NSS_DIR \
        -a "$FILEPATH" \
        $TO_EMAIL_ADDRESS
else
    MESSAGE_BODY="========== BACKUP TERMINADO COM SUCESSO =========="
    echo "$MESSAGE_BODY" | mailx -v -s "$EMAIL_SUBJECT" \
        -S smtp-use-starttls \
        -S ssl-verify=ignore \
        -S smtp=smtp://$SMTP_SERVER:$SMTP_PORT \
        -S from="$FROM_EMAIL_ADDRESS($FRIENDLY_NAME)" \
        -S smtp-auth-user=$SMTP_USER \
        -S smtp-auth-password=$SMTP_PASS \
        -S nss-config-dir=$NSS_DIR \
        -a "$FILEPATH" \
        $TO_EMAIL_ADDRESS
fi
